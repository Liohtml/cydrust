# WiFi and bridge connection config for the ESP32 firmware.
# Copy this file to .env and fill in your values before building firmware/.
# .env is git-ignored (contains credentials). This file is tracked.

# WiFi network the ESP32 will connect to.
VIBE_SSID=YourWiFiSSID
VIBE_PASS=YourWiFiPassword

# IP address of the machine running bridge/ on your local network.
VIBE_HOST=192.168.1.100

# Must match the port configured in bridge/config.toml.
VIBE_PORT=5151

# Must match the token configured in bridge/config.toml.
VIBE_TOKEN=your-secret-token-here
